# Database Configuration
SQL_CONN=Host=localhost;Database=MushroomMapApp;Username=postgres;Password=your_password
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DB=MushroomMapApp

# Redis Configuration
REDIS_CONN=localhost:6379,abortConnect=false

# API and CORS
API_URL=http://localhost:5000
CORS_URLS=http://localhost:5173,http://localhost:4173

# JWT Configuration
JWT_KEY=your_secure_random_jwt_secret_key_at_least_32_chars
JWT_TIME_EXPIRE_MINUTES=60
JWT_ISSUER=MushroomMapApp

# File Storage
FILES_STORAGE=Storage/Files

# Email Configuration (e.g., for Ethereal or SMTP)
EMAIL_HOST=smtp.example.com
EMAIL=noreply@example.com
EMAIL_FROMNAME=MushroomMapApp
EMAIL_USERNAME=your_username
EMAIL_PASSWORD=your_password
EMAIL_PORT=587

# Hangfire Dashboard Credentials
HANGFIRE_USERNAME=admin
HANGFIRE_PASSWORD=admin_password
